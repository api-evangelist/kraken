{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/kraken/refs/heads/main/json-schema/spot-rest-trades-history-response-schema.json",
  "title": "TradesHistoryResponse",
  "description": "TradesHistoryResponse schema from Kraken Spot REST API",
  "allOf": [
    {
      "type": "object",
      "properties": {
        "error": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Array of error strings; empty on success.",
          "example": []
        },
        "result": {
          "description": "Endpoint-specific result object.",
          "example": "string"
        }
      },
      "required": [
        "error"
      ]
    },
    {
      "type": "object",
      "properties": {
        "result": {
          "type": "object",
          "properties": {
            "trades": {
              "type": "object",
              "additionalProperties": {
                "$ref": "#/components/schemas/TradeInfo"
              },
              "example": {}
            },
            "count": {
              "type": "integer",
              "example": 1
            }
          },
          "example": {}
        }
      }
    }
  ]
}