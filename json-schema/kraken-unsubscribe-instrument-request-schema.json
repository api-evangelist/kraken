            "unsubscribe"
          ],
          "example": "unsubscribe"
        },
        "req_id": {
          "type": "integer",
          "example": "OQCLML-BW3P3-BUCMWZ"
        }
      }
    },
    {
      "type": "object",
      "properties": {
        "params": {
          "type": "object",
          "required": [
            "channel"
          ],
          "properties": {
            "channel": {
              "type": "string",
              "enum": [
                "instrument"
              ],
              "example": "instrument"
            }
          },
          "example": {}
        }
      }
    }
  ]
}