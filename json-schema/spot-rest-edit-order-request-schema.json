{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/kraken/refs/heads/main/json-schema/spot-rest-edit-order-request-schema.json",
  "title": "EditOrderRequest",
  "description": "EditOrderRequest schema from Kraken Spot REST API",
  "allOf": [
    {
      "type": "object",
      "description": "All private requests include an incrementing nonce. Optionally an OTP for two-factor-protected keys.",
      "required": [
        "nonce"
      ],
      "properties": {
        "nonce": {
          "type": "integer",
          "format": "int64",
          "example": 1717000000000
        },
        "otp": {
          "type": "string",
          "description": "Two-factor password / OTP if the key is OTP-protected.",
          "example": "123456"
        }
      }
    },
    {
      "type": "object",
      "required": [
        "txid",
        "pair"
      ],
      "properties": {
        "txid": {
          "type": "string",
          "example": "OQCLML-BW3P3-BUCMWZ"
        },
        "pair": {
          "type": "string",
          "example": "XBTUSD"
        },
        "volume": {
          "type": "string",
          "example": "0.01"
        },
        "displayvol": {
          "type": "string",
          "example": "0.01"
        },
        "price": {
          "type": "string",
          "example": "0.01"
        },
        "price2": {
          "type": "string",
          "example": "0.01"
        },
        "oflags": {
          "type": "string",
          "example": "string"
        },
        "deadline": {
          "type": "string",
          "example": "string"
        },
        "cancel_response": {
          "type": "boolean",
          "example": true
        },
        "validate": {
          "type": "boolean",
          "example": true
        },
        "userref": {
          "type": "integer",
          "example": 1
        }
      }
    }
  ]
}