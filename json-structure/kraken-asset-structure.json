{
  "$schema": "https://json-structure.org/json-structure/v0/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/kraken/refs/heads/main/json-structure/kraken-asset-structure.json",
  "name": "Asset",
  "type": "object",
  "description": "Asset schema from Kraken Spot WebSocket API v2",
  "properties": {
    "id": {
      "type": "string",
      "examples": [
        "OQCLML-BW3P3-BUCMWZ"
      ]
    },
    "status": {
      "type": "string",
      "examples": [
        "string"
      ]
    },
    "precision": {
      "type": "int64",
      "examples": [
        1
      ]
    },
    "precision_display": {
      "type": "int64",
      "examples": [
        1
      ]
    },
    "borrowable": {
      "type": "boolean",
      "examples": [
        true
      ]
    },
    "collateral_value": {
      "type": "double",
      "examples": [
        0.01
      ]
    },
    "margin_rate": {
      "type": "double",
      "examples": [
        "0.01"
      ]
    },
    "multiplier": {
      "type": "double",
      "examples": [
        0.01
      ]
    }
  }
}